{
  "name": "@kreattix/utils",
  "version": "1.0.10",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "start": "tsc && vite build --watch",
    "build": "tsc && vite build",
    "test": "jest --watch",
    "build:test": "jest",
    "lint": "eslint ./src/**/*.ts --config ./.eslintrc",
    "lint:fix": "eslint --fix ./src/**/*.ts --config ./.eslintrc",
    "format": "prettier --write ./src/**/*.ts --config ./.prettierrc",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/jest": "^29.2.5",
    "@typescript-eslint/eslint-plugin": "^5.48.0",
    "@typescript-eslint/parser": "^5.48.0",
    "eslint": "^8.31.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.0",
    "jest": "^29.3.1",
    "prettier": "^2.8.1",
    "ts-jest": "^29.0.3",
    "typescript": "^4.9.4",
    "vite": "^4.0.0",
    "vite-plugin-dts": "^1.7.1",
    "vite-plugin-linter": "^2.0.2",
    "vite-tsconfig-paths": "^4.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kreattix/utils.git"
  },
  "bugs": {
    "url": "https://github.com/kreattix/utils/issues"
  },
  "homepage": "https://github.com/kreattix/utils#readme",
  "keywords": [
    "kreattix",
    "design",
    "utils",
    "utility",
    "functions"
  ],
  "author": "Prince Patel",
  "license": "MIT",
  "dependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/react": "^18.3.3"
  }
}
